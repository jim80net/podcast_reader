{
  "manifest_version": 3,
  "name": "Podcast Reader",
  "version": "0.1.0",
  "description": "Transcribe the current page with the Podcast Reader desktop app: submit, watch progress, share logins for members-only sources.",
  "minimum_chrome_version": "120",
  "permissions": ["storage", "alarms", "notifications", "contextMenus", "activeTab"],
  "host_permissions": ["http://127.0.0.1/*"],
  "optional_permissions": ["cookies"],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
