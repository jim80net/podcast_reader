{
  "name": "podcast-reader-extension",
  "version": "0.1.0",
  "description": "Chrome extension (MV3) for the podcast-reader engine: transcribe the current tab, watch progress, share logins",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && node scripts/zip.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build"
  },
  "author": "Jim Park",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "0.1.43",
    "@types/node": "24.13.2",
    "eslint": "10.4.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vite": "7.3.5",
    "vitest": "4.1.8"
  }
}
