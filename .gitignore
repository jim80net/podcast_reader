# Virtual environment
.venv/

# Environment / secrets
.envrc
.env

# Claude Code local settings
.claude/

# Git worktrees
.worktrees/

# Superpowers brainstorm sessions
.superpowers/

# Explicitly selected product-walk artifacts are quarantined here before
# curation. The checked-in disposition manifests live under docs/walk-repros/.
.walk-repros/

# Audio files (large, download fresh)
*.mp3
*.wav
*.m4a
*.ogg
*.flac

# Whisper model cache
*.bin
*.pt

# yt-dlp download cache markers
*.ytdlp

# Whisper raw outputs (keep HTML, regenerate from JSON if needed)
*.json

# Generated transcripts (regenerate with json_to_html.py)
*.html

# Test fixtures are committed source artifacts, not generated outputs
!tests/fixtures/*.json
!tests/fixtures/*.html
!tests/fixtures/*.wav

# The Electron app (app/) is source, not generated artifacts; its own
# .gitignore covers node_modules/, dist/, out/
!app/**/*.json
!app/**/*.html

# Likewise the Chrome extension (extension/); its own .gitignore covers
# node_modules/, dist/, and the build zip
!extension/**/*.json
!extension/**/*.html
!src/podcast_reader/web_assets/*.html
!docs/walk-repros/*.json

# Python
__pycache__/
*.pyc
.gitnexus
*.title

# Packaging build outputs (diarization freeze smoke, engine builds)
packaging/.venv-*/
packaging/build/
packaging/dist/
packaging/.tool-cache/
