# Virtual environment
.venv/

# Environment / secrets
.envrc
.env

# Claude Code local settings
.claude/

# Git worktrees
.worktrees/

# Superpowers brainstorm sessions
.superpowers/

# Audio files (large, download fresh)
*.mp3
*.wav
*.m4a
*.ogg
*.flac

# Whisper model cache
*.bin
*.pt

# yt-dlp download cache markers
*.ytdlp

# Whisper raw outputs (keep HTML, regenerate from JSON if needed)
*.json

# Generated transcripts (regenerate with json_to_html.py)
*.html

# Test fixtures are committed source artifacts, not generated outputs
!tests/fixtures/*.json
!tests/fixtures/*.html

# The Electron app (app/) is source, not generated artifacts; its own
# .gitignore covers node_modules/, dist/, out/
!app/**/*.json
!app/**/*.html

# Python
__pycache__/
*.pyc
.gitnexus
*.title

# Packaging build outputs (diarization freeze smoke, engine builds)
packaging/.venv-*/
packaging/build/
packaging/dist/
