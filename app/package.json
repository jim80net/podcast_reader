{
  "name": "podcast-reader-app",
  "version": "0.1.0",
  "description": "Desktop shell for the podcast-reader engine (Electron)",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build-icons": "node scripts/build-icons.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.e2e.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --project e2e",
    "e2e:integration": "playwright test --project integration",
    "e2e:all": "playwright test",
    "dist": "electron-vite build && node scripts/dist.mjs",
    "dist:dir": "electron-vite build && node scripts/dist.mjs --dir"
  },
  "author": "Jim Park",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "24.13.2",
    "electron": "42.4.0",
    "electron-builder": "26.15.2",
    "electron-vite": "5.0.0",
    "eslint": "10.4.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vite": "7.3.5",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "electron-updater": "6.8.9"
  }
}
